# Supabase — get from supabase.com/dashboard/project/[id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API — for AI fallback + safety scanning
ANTHROPIC_API_KEY=your-anthropic-key

# Stripe — get from dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe dashboard
STRIPE_PRICE_SHORE_PLUS_MONTHLY=price_...
STRIPE_PRICE_SHORE_PLUS_YEARLY=price_...

# Resend — for transactional email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@shoreletter.app

# Inngest — for Wednesday Tide job queue
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Shore Letter
